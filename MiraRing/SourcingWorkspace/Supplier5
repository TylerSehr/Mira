}}; 
 //# sourceURL=e9166bf05d5398.js</script><script charset="utf-8">var function_31b3c24c49 = function() { try {
  // 非1688环境退出
  if (window.location.href.indexOf("1688.com") < 0) return false;

  var list = document.querySelectorAll("script");

  var init = function(resolve) {
    try {
      if (window.__skynet__baxia__inited__) {
        return resolve(true);
      }

      baxiaCommon && baxiaCommon.init({
        "mergeApiPath": true,
        "appendTo": "querystring",  // 修正：使用有效值
        "paramsType": ["uab", "umid", "et"],
        "checkApiPath": function(url) {
          // 修正：明确返回布尔值
          return url.indexOf('/engine/api/engine/launch/execute') > -1;
        }
      });

      var startTime = Date.now();
      var maxWaitTime = 5000; // 最大等待时间

      var timer = setInterval(() => {
        var elapsed = Date.now() - startTime;

        // 超时处理
        if (elapsed > maxWaitTime) {
          clearInterval(timer);
          console.warn('baxia init timeout');
          resolve(false); // 超时返回 false
          return;
        }
        if(!window.__baxia__) return;
        if(!window.__baxia__.baxiaPromptInit || !window.__baxia__.getFYModule || typeof baxiaCommon.init !== 'function') return;
        // 检查火眼模块是否就绪
        var fyModule = window.__baxia__.getFYModule ;

        if (fyModule && fyModule.getFYToken) {
          var token = fyModule.getFYToken();
          if (token && token.indexOf("default") === -1 && token.indexOf("fast") === -1) {
            clearInterval(timer);
            window.__skynet__baxia__inited__ = true;
            console.log('baxia is ready, token:', token);
            resolve(true);
            return;
          }
        }
      }, 100);

    } catch (e) {
      console.error('baxia init error:', e);
      resolve(false);
    }
  };

  var judgeBaxiaExist = (resolve)=>{
    var startJudge = Date.now()
    var judgeTimer = setInterval(()=>{
      if(typeof baxiaCommon !== 'undefined' && typeof __baxia__ !== undefined && window.__baxia__ && window.__baxia__.baxiaPromptInit){
        init(resolve);
        clearInterval(judgeTimer);
        return;
      }
      if(Date.now - startJudge > 1000 * 5){
        clearInterval(judgeTimer);
        console.warn('baxia init timeout');
        resolve(false);
      }
    }, 200)
  }

  // 检查脚本是否已加载
  for (let i = 0; i < list.length; i++) {
    if (list[i].src.indexOf("baxia-entry/baxiaCommon") >= 0) {
      return new Promise(resolve => judgeBaxiaExist(resolve));
    }
  }

  // 动态加载脚本
  return new Promise((resolve) => {
    var script = document.createElement("script");
    // 建议：分开加载，让 baxiaCommon 自动加载其依赖
    script.src = "//g.alicdn.com/sd/baxia-entry/baxiaCommon.js";
    script.charset = 'utf-8';
    script.crossOrigin = 'anonymous';
    script.onload = () => judgeBaxiaExist(resolve);
    script.onerror = () => {
      console.error('baxia script load failed');
      resolve(false);
    };
    document.body.appendChild(script);

    window.__flow_launch_ex_params__ = Object.assign(
      (window.__flow_launch_ex_params__ || {}),
      { scene_code: "redPack" }
    );
  });

} catch (error) {
  console.error('baxia function error:', error);
  return false;
}}; 
